{
	"name": "@forja/cli",
	"version": "0.1.0",
	"description": "Command-line tools for Forja framework",
	"author": "Forja Contributors",
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"bin": {
		"forja": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@forja/core": "workspace:*",
		"@forja/types": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^20.11.17",
		"jiti": "^2.6.1",
		"tsup": "^8.0.2",
		"typescript": "^5.3.3"
	}
}
