{
	"name": "@forja/cli",
	"version": "0.1.0",
	"description": "Command-line tools for Forja framework",
	"author": "Forja Contributors",
	"license": "MIT",
	"homepage": "https://tryforja.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/myniqx/forja.git",
		"directory": "packages/cli"
	},
	"bugs": {
		"url": "https://github.com/myniqx/forja/issues"
	},
	"keywords": [
		"cli",
		"typescript",
		"migrate",
		"codegen",
		"forja"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"bin": {
		"forja": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"peerDependencies": {
		"@forja/core": "^0.1.0"
	},
	"dependencies": {
		"adm-zip": "^0.5.16",
		"archiver": "^7.0.1"
	},
	"devDependencies": {
		"@forja/core": "workspace:*",
		"@types/adm-zip": "^0.5.8",
		"@types/archiver": "^7.0.0",
		"@types/node": "^20.11.17",
		"jiti": "^2.6.1",
		"tsup": "^8.0.2",
		"typescript": "^5.3.3"
	}
}
