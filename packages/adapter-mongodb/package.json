{
	"name": "@datrix/adapter-mongodb",
	"version": "0.1.1",
	"description": "MongoDB adapter for Datrix framework",
	"author": "Datrix Contributors",
	"license": "MIT",
	"homepage": "https://datrix.dev",
	"repository": {
		"type": "git",
		"url": "https://github.com/myniqx/datrix.git",
		"directory": "packages/adapter-mongodb"
	},
	"bugs": {
		"url": "https://github.com/myniqx/datrix/issues"
	},
	"keywords": [
		"database",
		"orm",
		"typescript",
		"mongodb",
		"nosql",
		"adapter",
		"datrix"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"peerDependencies": {
		"@datrix/core": "^0.1.1"
	},
	"dependencies": {
		"mongodb": "^6.3.0"
	},
	"devDependencies": {
		"@datrix/core": "workspace:*",
		"tsup": "^8.0.2",
		"typescript": "^5.3.3"
	}
}
