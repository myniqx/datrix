{
	"name": "@forja/core",
	"version": "0.1.0",
	"description": "Core functionality for Forja framework - schema, validation, query building, migration",
	"author": "Forja Contributors",
	"license": "MIT",
	"homepage": "https://tryforja.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/myniqx/forja.git",
		"directory": "packages/core"
	},
	"bugs": {
		"url": "https://github.com/myniqx/forja/issues"
	},
	"keywords": [
		"database",
		"orm",
		"typescript",
		"schema",
		"query-builder",
		"migration",
		"type-safe"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"tsup": "^8.0.2",
		"typescript": "^5.3.3"
	}
}
