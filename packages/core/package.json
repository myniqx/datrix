{
	"name": "@forja/core",
	"version": "0.1.0",
	"description": "Core functionality for Forja framework - schema, validation, query building, migration",
	"author": "Forja Contributors",
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./src/index.ts",
		"./*": "./src/*.ts",
		"./types/api": "./src/types/api/index.ts",
		"./types/cli": "./src/types/cli/index.ts",
		"./types/adapter": "./src/types/adapter/index.ts",
		"./types/errors": "./src/types/errors/index.ts",
		"./utils": "./src/types/utils/index.ts",
		"./types": "./src/types/core/index.ts"
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"tsup": "^8.0.2",
		"typescript": "^5.3.3"
	}
}
