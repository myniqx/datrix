{
	"name": "@forja/api-upload",
	"version": "0.1.0",
	"description": "File upload extension for Forja API plugin",
	"author": "Forja Contributors",
	"license": "MIT",
	"homepage": "https://tryforja.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/myniqx/forja.git",
		"directory": "packages/api-upload"
	},
	"bugs": {
		"url": "https://github.com/myniqx/forja/issues"
	},
	"keywords": [
		"upload",
		"file",
		"typescript",
		"s3",
		"image",
		"forja"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"peerDependencies": {
		"@forja/core": "^0.1.0",
		"@forja/api": "^0.1.0"
	},
	"dependencies": {
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@forja/core": "workspace:*",
		"@forja/api": "workspace:*",
		"@types/sharp": "^0.32.0",
		"tsup": "^8.5.1",
		"typescript": "^5.3.3"
	}
}
