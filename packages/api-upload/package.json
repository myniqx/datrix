{
	"name": "@forja/api-upload",
	"version": "0.1.0",
	"description": "File upload extension for Forja API plugin",
	"author": "Forja Contributors",
	"license": "MIT",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"sharp": "^0.34.5",
		"@forja/api": "workspace:*",
		"@forja/core": "workspace:*"
	},
	"devDependencies": {
		"@types/sharp": "^0.32.0",
		"tsup": "^8.5.1",
		"typescript": "^5.3.3"
	}
}
