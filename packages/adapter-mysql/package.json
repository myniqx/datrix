{
	"name": "forja-adapter-mysql",
	"version": "0.1.0",
	"description": "MySQL adapter for Forja framework",
	"author": "Forja Contributors",
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"forja-types": "workspace:*",
		"mysql2": "^3.9.1"
	},
	"devDependencies": {
		"tsup": "^8.0.2",
		"typescript": "^5.3.3"
	}
}
