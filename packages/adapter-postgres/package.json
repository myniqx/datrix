{
	"name": "@forja/adapter-postgres",
	"version": "0.1.0",
	"description": "PostgreSQL adapter for Forja framework",
	"author": "Forja Contributors",
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"pg": "^8.11.3",
		"@forja/core": "workspace:*"
	},
	"devDependencies": {
		"tsup": "^8.0.2",
		"typescript": "^5.3.3",
		"@types/pg": "^8.11.0"
	}
}
