{
	"name": "forja-api",
	"version": "0.1.0",
	"description": "HTTP request handling, query parsing, and response serialization for Forja framework",
	"author": "Forja Contributors",
	"license": "MIT",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*/index.ts",
			"import": "./src/*/index.ts",
			"default": "./src/*/index.ts"
		}
	},
	"typesVersions": {
		"*": {
			"*": [
				"./src/*/index.ts"
			]
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"forja-core": "workspace:*",
		"forja-types": "workspace:*"
	},
	"devDependencies": {
		"tsup": "^8.0.2",
		"typescript": "^5.3.3",
		"vitest": "^1.2.2"
	}
}
