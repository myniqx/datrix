{
  "name": "forja",
  "version": "0.1.0",
  "description": "TypeScript-first database management framework with Strapi-like API flexibility",
  "author": "Forja Contributors",
  "license": "MIT",
  "homepage": "https://github.com/myniqx/forja#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/myniqx/forja.git"
  },
  "bugs": {
    "url": "https://github.com/myniqx/forja/issues"
  },
  "keywords": [
    "database",
    "orm",
    "typescript",
    "strapi",
    "cms",
    "rest-api",
    "query-builder",
    "postgresql",
    "mysql",
    "mongodb",
    "type-safe",
    "plugin-architecture"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "forja": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.mjs",
      "require": "./dist/adapters/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.mjs",
      "require": "./dist/plugins/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.mjs",
      "require": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run type-check && pnpm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.18.2",
  "dependencies": {
    "pg": "^8.11.3",
    "mysql2": "^3.9.1",
    "mongodb": "^6.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2",
    "@vitest/coverage-v8": "^1.2.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
