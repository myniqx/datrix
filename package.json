{
  "name": "forja-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript-first database management framework with Strapi-like API flexibility",
  "author": "Forja Contributors",
  "license": "MIT",
  "homepage": "https://github.com/myniqx/forja#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/myniqx/forja.git"
  },
  "bugs": {
    "url": "https://github.com/myniqx/forja/issues"
  },
  "keywords": [
    "database",
    "orm",
    "typescript",
    "strapi",
    "cms",
    "rest-api",
    "query-builder",
    "postgresql",
    "mysql",
    "mongodb",
    "type-safe",
    "plugin-architecture"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "type-check": "pnpm -r run type-check",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json}\"",
    "test": "pnpm -r run test && vitest run tests/integration",
    "test:unit": "pnpm -r run test",
    "test:integration": "vitest run tests/integration",
    "test:watch": "pnpm -r run test:watch",
    "test:coverage": "pnpm -r run test:coverage",
    "clean": "pnpm -r run clean"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
